# 数据库配置
DB_URL=jdbc:mysql://localhost:3306/agent_customer_service?useUnicode=true&characterEncoding=utf8&serverTimezone=GMT%2B8&useSSL=false&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=your_password

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Druid 监控控制台
DRUID_USERNAME=admin
DRUID_PASSWORD=your_druid_password

# LLM 配置（OneRouter）
LLM_ENABLED=false
LLM_API_URL=https://api.onerouter.top/v1/chat/completions
LLM_API_KEY=your_api_key_here
LLM_MODEL=gpt-4o-mini
