# ==========================================
# 🔐 本地敏感配置
# ==========================================
# 使用方法：
#   1. 复制本文件，重命名为 application-local.yml
#   2. 填入你自己的配置
#   3. application-local.yml 已被 .gitignore 排除，不会上传 GitHub
# ==========================================

spring:
  datasource:
    url: jdbc:mysql://localhost:3306/agent_customer_service?useUnicode=true&characterEncoding=utf8&serverTimezone=GMT%2B8&useSSL=false&allowPublicKeyRetrieval=true
    username: root
    password: your_mysql_password               # ← 填你的 MySQL 密码

  data:
    redis:
      host: localhost
      port: 6379
      password:                                  # ← 如有密码则填入

# ==========================================
# 🤖 LLM 大模型配置（OneRouter 统一网关）
# ==========================================
# 注册地址：https://onerouter.top
# 注册后获取 API Key，填入下方即可
llm:
  enabled: false                                 # ← 改为 true 启用 LLM（默认关闭，使用规则引擎兜底）
  api-url: https://api.onerouter.top/v1/chat/completions
  api-key: your_api_key_here                     # ← 填你的 API Key
  model: gpt-4o-mini                             # ← 可选模型：gpt-4o-mini / deepseek-chat 等

# ==========================================
# 📊 Druid 监控台（可选）
# ==========================================
# 访问地址: http://localhost:10002/druid/
# 默认账密为 admin/admin，如需修改取消下方注释：
# spring:
#   datasource:
#     druid:
#       stat-view-servlet:
#         login-username: your_username
#         login-password: your_password
